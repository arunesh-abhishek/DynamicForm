{
  "theme": {
    "background_color": "#FFFFFF",
    "text_color": "#111827",
    "border_color": "#D1D5DB",
    "error_color": "#B91C1C"
  },
  "form_title": "Comprehensive Campaign Setup",
  "fields": [
    {
      "id": "campaign_name",
      "order": 1,
      "type": "TEXT",
      "subtype": "MULTILINE",
      "label": "Campaign Name",
      "default_value": "Summer Sale 2026 Extended Promotional Edition",
      "max_length": 20,
      "error_message": "Name is required and cannot exceed 20 characters.",
      "required": true
    },
    {
      "id": "daily_budget",
      "order": 2,
      "type": "TEXT",
      "subtype": "NUMBER",
      "label": "Daily Budget ($)",
      "placeholder": "0.00",
      "error_message": "Budget is required.",
      "required": true
    },
    {
      "id": "destination_url",
      "order": 3,
      "type": "TEXT",
      "subtype": "URI",
      "label": "Destination URL",
      "placeholder": "https://",
      "required": true
    },
    {
      "id": "ad_networks",
      "order": 4,
      "type": "DROPDOWN",
      "label": "Ad Networks",
      "allow_multiple": true,
      "error_message": "Please select at least one network.",
      "required": true,
      "options": [
        {
          "id": "net_google",
          "label": "Google Search"
        },
        {
          "id": "net_meta",
          "label": "Meta Platforms"
        },
        {
          "id": "net_tiktok",
          "label": "TikTok"
        }
      ]
    },
    {
      "id": "billing_account",
      "order": 5,
      "type": "DROPDOWN",
      "label": "Billing Account",
      "required": true,
      "options": [
        {
          "id": "acct_primary",
          "label": "Primary Billing Account"
        },
        {
          "id": "acct_backup",
          "label": "Backup Billing Account"
        }
      ]
    },
    {
      "id": "enable_ai_opt",
      "order": 8,
      "type": "TOGGLE",
      "label": "Enable AI Bidding Optimization",
      "default_value": true,
      "required": false
    },
    {
      "id": "admin_password",
      "order": 9,
      "type": "TEXT",
      "subtype": "SECURE",
      "label": "Admin Password",
      "error_message": "Password validation required.",
      "required": true
    },
    {
      "id": "accept_legal",
      "order": 10,
      "type": "CHECKBOX",
      "label": "I have read and agree to the Terms of Service and Privacy Policy.",
      "error_message": "You must accept the legal terms to launch.",
      "required": true,
      "metadata": {
        "Terms of Service": "https://example.com/terms",
        "Privacy Policy": "https://example.com/privacy",
        "clickable_text_color": "#BB86FC"
      }
    }
  ]
}
